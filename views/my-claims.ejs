<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Claims</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
            color: #333;
        }

        .main-content {
            padding: 30px 20px;
            flex: 1;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 24px;
            padding: 10px 18px;
            text-decoration: none;
            color: #4f46e5;
            background-color: #ede9fe;
            font-size: 14px;
            font-weight: 600;
            border-radius: 50px;
            transition: all 0.2s ease;
        }

        .back-btn:hover {
            background-color: #ddd6fe;
            color: #4338ca;
            transform: translateY(-1px);
        }

        .back-btn:active {
            transform: translateY(0);
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 24px;
        }

        #claimsContainer {
            max-width: 900px;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        #claimsContainer p {
            color: #555;
            font-size: 15px;
        }

        .claim-card {
            border: 1px solid #dde1f0;
            padding: 20px;
            margin: 12px 0;
            border-radius: 10px;
            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            transition: box-shadow 0.2s;
        }

        .claim-card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
        }

        .claim-card p {
            margin-bottom: 10px;
            font-size: 15px;
            line-height: 1.5;
            color: #444;
        }

        .claim-card p:last-child {
            margin-bottom: 0;
        }

        .claim-card p strong {
            color: #1a1a2e;
            font-weight: 600;
            margin-right: 6px;
        }

        .status-badge {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }

        .status-approved {
            color: #1a7a4a;
            background-color: #d4f4e2;
        }

        .status-rejected {
            color: #b91c1c;
            background-color: #fde8e8;
        }

        .status-pending {
            color: #92580a;
            background-color: #fef3cd;
        }

        .error-msg {
            color: #b91c1c;
            background: #fde8e8;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
        }
    </style>
</head>

<body>
    <%- include('partials/navTitle') %>
    <div class="main-content">
        <a href="/items-page" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Back to Items</a>
        <h1>My Claims</h1>
        <div id="claimsContainer">Loading claims...</div>
    </div>
</div> <!-- Close app-body -->

    <script>
        async function fetchMyClaims() {
            const token = localStorage.getItem('token');

            if (!token) {
                window.location.href = '/login';
                return;
            }

            try {
                const response = await fetch('/api/my-claims', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                const data = await response.json();
                const container = document.getElementById('claimsContainer');

                if (response.ok && data.claims.length > 0) {
                    container.innerHTML = data.claims.map(claim => `
                        <div class="claim-card">
                            <p><strong>Claim ID:</strong> ${claim.claim_id}</p>
                            <p><strong>Item ID:</strong> ${claim.item_id}</p>
                            <p><strong>Proof:</strong> ${claim.proof_description}</p>
                            <p><strong>Identifying Feature:</strong> ${claim.identifying_feature}</p>
                            <p><strong>Status:</strong> 
                                <span class="status-badge status-${claim.claim_status.toLowerCase()}">
                                    ${claim.claim_status.charAt(0).toUpperCase() + claim.claim_status.slice(1)}
                                </span>
                            </p>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = '<p>You have not made any claims yet.</p>';
                }

            } catch (error) {
                document.getElementById('claimsContainer').innerHTML =
                    `<p style="color:red">Error: ${error.message}</p>`;
            }
        }

        fetchMyClaims();
    </script>
</body>

</html>