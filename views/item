    <div class="hero-text">
        <p class="hero-greeting" id="heroGreeting">Good morning 👋</p>
        <h2 class="hero-title">Welcome back, <span id="heroName">there</span>!</h2>
        <p class="hero-sub">Find and recover your lost items across campus.</p>
    </div>
</div>


<div class="dashboard-layout">
    <div class="left-column">
        <div class="content-box">
            <div class="content-inner">

                <!-- TOPBAR -->
                <div class="topbar">
                    <h1>All Items</h1>
                    <div class="topbar-links">
                        <a href="/report-lost" class="link-btn link-btn-primary">Report Lost Item</a>
                        <a href="/report-found" class="link-btn link-btn-primary">Report Found Item</a>
                        <a href="/my-claims" class="link-btn link-btn-outline">My Claims</a>
                        <a href="/my-items" class="link-btn link-btn-outline">My Items</a>
                    </div>
                </div>

                <!-- SEARCH -->
                <form id="searchForm" class="search-bar">
                    <input type="text" id="searchInput" name="keyword" placeholder="Search items...">
                    <button type="submit">Search</button>
                </form>

                <hr>

                <div id="itemsContainer">Loading items...</div>

            </div>
        </div>

    </div>
    
    <!-- Right side column for extra features -->
    <div class="right-column">
        <h3 style="font-size: 18px; margin-bottom: 12px; color: #1a1a2e;">Extra Features</h3>
        <p style="font-size: 14px; color: #6b7280; line-height: 1.5;">You can add more features here on the right side.</p>
    </div>
</div> <!-- End dashboard-layout -->
</div>
</div> <!-- End main-section opened by navTitle -->

<script>
    function toggleSidebar() {
        const sidebar = document.querySelector(".sidebar");
        if(sidebar) sidebar.classList.toggle("hide");
    }
</script>

    <script>
        document.getElementById('searchForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const keyword = document.getElementById('searchInput').value;
            fetchItems(keyword);
        });

        async function fetchItems(keyword = '') {
            try {
                const url = keyword ? '/search?keyword=' + encodeURIComponent(keyword) : '/items';
                const response = await fetch(url);
                const result = await response.json();
                const container = document.getElementById('itemsContainer');

                if (response.ok && result.items) {
                    if (result.items.length === 0) {
                        container.innerHTML = '<p>No items found.</p>';
                        return;
                    }
                    container.innerHTML = result.items.map(item => `
                        <div class="item-card">
                            ${item.image_url ? `<img src="/uploads/${item.image_url}" alt="${item.item_name}">` : ''}
                            <h3>${item.item_name}</h3>
                            <p><strong>Type:</strong> ${item.item_type}</p>
                            <p><strong>Category:</strong> ${item.category}</p>
                            <p><strong>Description:</strong> ${item.description}</p>
                            <a href="/item-page/${item.item_id}" class="view-btn">View Details</a>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = `<p class="error">${result.message || 'Failed to load items.'}</p>`;
                }
            } catch (error) {
                document.getElementById('itemsContainer').innerHTML =
                    `<p class="error">Error: ${error.message}</p>`;
            }
        }

        fetchItems();

        // Highlight active nav item
    const path = window.location.pathname;
    document.querySelectorAll('.nav-item[data-path]').forEach(el => {
        if (el.dataset.path === path) el.classList.add('active');
    });

    const user = JSON.parse(localStorage.getItem('user') || '{}');
if (user.full_name) {
    document.getElementById('userName').textContent = user.full_name;
    document.getElementById('userAvatar').textContent =
        user.full_name.split(' ').map(n => n[0]).join('').toUpperCase();
    document.getElementById('heroName').textContent = user.full_name.split(' ')[0];
}

// Dynamic greeting based on time
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Good morning 👋' : hour < 18 ? 'Good afternoon 👋' : 'Good evening 👋';
document.getElementById('heroGreeting').textContent = greeting;
    </script>

</body>
</html>
