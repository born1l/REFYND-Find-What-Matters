<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Reported Items | REFYND</title>
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .page-title {
            font-size: 24px;
            font-weight: 700;
            color: #1e293b;
            letter-spacing: -0.5px;
        }

        .items-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 24px;
        }

        .item-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 24px;
            border: 1px solid #e8edf5;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .item-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.08), 0 8px 10px -5px rgba(0, 0, 0, 0.04);
            border-color: #cbd5e1;
        }

        .item-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .item-card:hover::before {
            opacity: 1;
        }

        .item-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .item-title {
            font-size: 18px;
            font-weight: 600;
            color: #0f172a;
            margin: 0;
            line-height: 1.3;
        }

        .item-status {
            font-size: 11px;
            font-weight: 700;
            padding: 5px 12px;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-lost {
            background: #fef2f2;
            color: #ef4444;
            border: 1px solid #fecaca;
        }

        .status-found {
            background: #f0fdf4;
            color: #22c55e;
            border: 1px solid #bbf7d0;
        }
        
        .status-resolved {
            background: #f1f5f9;
            color: #64748b;
            border: 1px solid #e2e8f0;
        }

        .item-desc {
            font-size: 14px;
            color: #64748b;
            line-height: 1.6;
            margin-bottom: 24px;
            flex: 1;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .item-actions {
            display: flex;
            gap: 12px;
            margin-top: auto;
            border-top: 1px solid #f1f5f9;
            padding-top: 20px;
        }

        .btn {
            flex: 1;
            padding: 10px 14px;
            border-radius: 10px;
            font-size: 13.5px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            border: none;
        }

        .btn-edit {
            background: #f8fafc;
            color: #4f46e5;
            border: 1.5px solid #e2e8f0;
        }

        .btn-edit:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

        .btn-delete {
            background: #fff;
            color: #ef4444;
            border: 1.5px solid #fecaca;
        }

        .btn-delete:hover {
            background: #fef2f2;
        }

        /* Empty State */
        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 80px 20px;
            text-align: center;
            background: #ffffff;
            border-radius: 20px;
            border: 2px dashed #cbd5e1;
            color: #64748b;
            grid-column: 1 / -1;
        }

        .empty-icon {
            font-size: 56px;
            color: #94a3b8;
            margin-bottom: 20px;
        }
        
        .empty-state h3 {
            font-size: 20px;
            color: #1e293b;
            margin-bottom: 12px;
            font-weight: 700;
        }

        .empty-state p {
            font-size: 15px;
            margin-bottom: 28px;
            max-width: 420px;
            line-height: 1.5;
        }

        .btn-primary {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14.5px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: opacity 0.2s, transform 0.1s;
            border: none;
            cursor: pointer;
        }

        .btn-primary:hover {
            opacity: 0.95;
            transform: translateY(-1px);
        }
        
        .btn-primary:active {
            transform: translateY(0);
        }

        /* Loading Spinner */
        .loader-container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 300px;
            grid-column: 1 / -1;
        }

        .spinner {
            width: 44px;
            height: 44px;
            border: 3.5px solid rgba(79, 70, 229, 0.1);
            border-radius: 50%;
            border-top-color: #4f46e5;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <%- include('partials/navTitle') %>
    <div class="main-content" style="padding: 32px 40px; flex: 1;">
        <div class="page-header">
            <h1 class="page-title">My Reported Items</h1>
            <a href="/report-lost" class="btn-primary">
                <i class="fa-solid fa-plus"></i> Report New
            </a>
        </div>

        <div id="itemsContainer">
            <div class="loader-container">
                <div class="spinner"></div>
            </div>
        </div>
    </div>
</div> <!-- Close app-body -->

    <script>
    async function fetchMyItems() {
        const token = localStorage.getItem('token');

        if (!token) {
            window.location.href = '/login';
            return;
        }

        try {
            const response = await fetch('/api/my-items', {
                headers: { 
                    'Authorization': `Bearer ${token}` 
                }
            });

            const items = await response.json();
            const container = document.getElementById('itemsContainer');

            if (items.length === 0) {
                container.className = '';
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fa-solid fa-box-open empty-icon"></i>
                        <h3>No Items Found</h3>
                        <p>You haven't reported any lost or found items yet. Once you do, they will appear here and you can manage them easily.</p>
                        <a href="/report-lost" class="btn-primary"><i class="fa-solid fa-plus"></i> Report an Item</a>
                    </div>
                `;
                return;
            }

            container.className = 'items-grid';
            
            container.innerHTML = items.map(item => {
                let statusClass = 'status-resolved';
                if (item.status && item.status.toLowerCase() === 'lost') statusClass = 'status-lost';
                if (item.status && item.status.toLowerCase() === 'found') statusClass = 'status-found';
                
                return `
                <div class="item-card">
                    <div class="item-header">
                        <h3 class="item-title">${escapeHTML(item.item_name)}</h3>
                        <span class="item-status ${statusClass}">${escapeHTML(item.status || 'Unknown')}</span>
                    </div>
                    <p class="item-desc">${escapeHTML(item.description)}</p>
                    
                    <div class="item-actions">
                        <button class="btn btn-edit" onclick="editItem(${item.item_id})">
                            <i class="fa-regular fa-pen-to-square"></i> Edit
                        </button>
                        <button class="btn btn-delete" onclick="deleteItem(${item.item_id})">
                            <i class="fa-regular fa-trash-can"></i> Delete
                        </button>
                    </div>
                </div>
            `}).join('');

        } catch (error) {
            console.error('fetchMyItems error:', error);
            const container = document.getElementById('itemsContainer');
            container.innerHTML = '<div class="empty-state"><p style="color:#ef4444; font-weight: 600;">Failed to load items. Please try again.</p></div>';
        }
    }

    function escapeHTML(str) {
        if (!str) return '';
        return str.toString().replace(/[&<>'"]/g, 
            tag => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                "'": '&#39;',
                '"': '&quot;'
            }[tag] || tag)
        );
    }

    async function deleteItem(id) {
        if (!confirm('Are you sure you want to delete this item?')) return;
        const token = localStorage.getItem('token');
        try {
            const response = await fetch(`/delete-item/${id}`, {
                method: 'DELETE',
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            });
            const result = await response.json();
            if (response.ok) {
                fetchMyItems(); 
            } else {
                alert(result.message || 'Failed to delete item.');
            }
        } catch (error) {
            console.error('deleteItem error:', error);
            alert('Error deleting item');
        }
    }

    function editItem(id) {
        const token = localStorage.getItem('token');
        if (!token) {
            window.location.href = '/login';
            return;
        }
        window.location.href = `/edit-item/${id}?token=${token}`;
    }

    fetchMyItems();
    </script>
</body>
</html>